<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Feedback"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvSessionInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session results"
            android:textSize="14sp"
            android:textColor="#6C757D"
            android:layout_marginBottom="24dp" />

        <!-- Overall Score Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overall Score"
                    android:textSize="16sp"
                    android:textColor="#6C757D"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvOverallScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="#6C63FF"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="out of 100"
                    android:textSize="14sp"
                    android:textColor="#6C757D" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Score Breakdown -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Score Breakdown"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="16dp" />

                <!-- Pace -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pace" android:textColor="#6C757D" android:layout_marginBottom="4dp"/>
                <ProgressBar android:id="@+id/progressPace"
                    android:layout_width="match_parent" android:layout_height="8dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:max="100" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvPaceScore" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0/100"
                    android:textColor="#6C63FF" android:layout_marginBottom="12dp"/>

                <!-- Clarity -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Clarity" android:textColor="#6C757D" android:layout_marginBottom="4dp"/>
                <ProgressBar android:id="@+id/progressClarity"
                    android:layout_width="match_parent" android:layout_height="8dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:max="100" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvClarityScore" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0/100"
                    android:textColor="#6C63FF" android:layout_marginBottom="12dp"/>

                <!-- Confidence -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Confidence" android:textColor="#6C757D" android:layout_marginBottom="4dp"/>
                <ProgressBar android:id="@+id/progressConfidence"
                    android:layout_width="match_parent" android:layout_height="8dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:max="100" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvConfidenceScore" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0/100"
                    android:textColor="#6C63FF" android:layout_marginBottom="12dp"/>

                <!-- Content -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Content" android:textColor="#6C757D" android:layout_marginBottom="4dp"/>
                <ProgressBar android:id="@+id/progressContent"
                    android:layout_width="match_parent" android:layout_height="8dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:max="100" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvContentScore" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0/100"
                    android:textColor="#6C63FF" android:layout_marginBottom="12dp"/>

                <!-- Structure -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Structure" android:textColor="#6C757D" android:layout_marginBottom="4dp"/>
                <ProgressBar android:id="@+id/progressStructure"
                    android:layout_width="match_parent" android:layout_height="8dp"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:max="100" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvStructureScore" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0/100"
                    android:textColor="#6C63FF" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- AI Feedback -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Coach Feedback"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#495057"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Strengths -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Strengths"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#28A745"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvStrengths"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#495057"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Improvements -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 Improvements"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#DC3545"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvImprovements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:textColor="#495057"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Practice Again Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPracticeAgain"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Practice Again"
            android:textSize="16sp"
            android:backgroundTint="#6C63FF"
            android:layout_marginBottom="12dp" />

    </LinearLayout>
</ScrollView>