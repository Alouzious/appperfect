<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FFFFFF"
            app:title="@string/toolbar_title"
            app:titleTextColor="#111827"
            app:elevation="0dp" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F9FAFB"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/choose_style"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:letterSpacing="0.005"
                android:layout_marginBottom="12dp" />

            <Spinner
                android:id="@+id/spinnerPitchType"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="24dp"
                android:padding="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp"
                    android:background="#FFFFFF">

                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/timer_default"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:letterSpacing="0.01"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvRecordingStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_ready"
                        android:textSize="14sp"
                        android:textColor="#6B7280"
                        android:layout_marginBottom="16dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E5E7EB"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvTranscript"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="80dp"
                        android:text="@string/transcript_hint"
                        android:textSize="15sp"
                        android:textColor="#374151"
                        android:textStyle="italic"
                        android:gravity="center"
                        android:padding="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_begin"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#6366F1"
                android:layout_marginBottom="12dp"
                app:icon="@drawable/ic_microphone"
                app:iconGravity="textStart"
                app:iconSize="24dp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_stop"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#EF4444"
                android:layout_marginBottom="12dp"
                android:enabled="false"
                app:icon="@drawable/ic_stop"
                app:iconGravity="textStart"
                app:iconSize="24dp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMockData"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_mock"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#10B981"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                app:icon="@drawable/ic_feedback"
                app:iconGravity="textStart"
                app:cornerRadius="12dp" />

            <LinearLayout
                android:id="@+id/layoutProcessing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="24dp">

                <ProgressBar
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginBottom="12dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#6366F1" />

                <TextView
                    android:id="@+id/tvProcessingStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/processing_status"
                    android:textSize="14sp"
                    android:textColor="#6B7280"
                    android:textStyle="italic" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pitch_journey"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:letterSpacing="0.005"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>